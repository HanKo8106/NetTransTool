<Window x:Class="NetTransTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="多國語言翻譯工具 v1.0"
        Width="750" Height="580"
        MinWidth="520" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        FontFamily="Microsoft JhengHei UI"
        FontSize="12">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 頂部：元件選擇 -->
        <Border Grid.Row="0" Padding="12,10,12,6">
            <StackPanel>
                <TextBlock Text="選擇元件：" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="cmbComponent" Grid.Column="0" Height="26"/>
                    <Button x:Name="btnLoad" Grid.Column="2" Content="載入元件清單"
                            Height="28" Click="BtnLoad_Click"/>
                </Grid>
                <CheckBox x:Name="chkSyncRoot"
                          Content="同步更新根目錄 Resources.resx 與 Lang/Resources.resx（使用 English 值）"
                          IsChecked="True" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- 執行列 -->
        <Border Grid.Row="1" Padding="12,8,12,4">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnTranslate" Content="執行翻譯"
                        Width="120" Height="30" Margin="0,0,10,0"
                        Click="BtnTranslate_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#0078D7"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#005A9E"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#004275"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#AAAAAA"/>
                                                <Setter Property="Foreground" Value="#666666"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="btnClear" Content="清除記錄"
                        Width="90" Height="30" Click="BtnClear_Click"/>
            </StackPanel>
        </Border>

        <!-- 記錄區 -->
        <Grid Grid.Row="2" Margin="8,0,8,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="執行記錄：" Margin="0,0,0,2"/>
            <TextBox x:Name="txtLog" Grid.Row="1"
                     IsReadOnly="True"
                     HorizontalScrollBarVisibility="Auto"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     FontFamily="Consolas" FontSize="12"
                     Background="#1C1C1C" Foreground="#DCDCDC"
                     BorderThickness="1" Padding="4"/>
        </Grid>

        <!-- 狀態列 -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock x:Name="lblStatus"
                           Text="就緒　－　請先點「載入元件清單」"
                           Margin="6,0,0,0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
